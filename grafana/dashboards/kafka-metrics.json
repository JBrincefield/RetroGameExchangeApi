  "panels": [
    {
      "title": "Kafka Topics - Messages In Per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(kafka_topic_partition_current_offset[1m])) by (topic)",
          "legendFormat": "{{topic}}",
          "refId": "A"
